# Copy to .env and fill in (do not commit .env)
#   copy .env.example .env

# Production API (HTTPS required for release APKs on Android)
API_BASE_URL=https://spendlogweb.netlify.app/api/v1

# Local dev only (flutter run on same Wi‑Fi; HTTP works in debug builds)
# API_BASE_URL=http://192.168.29.78:3000/api/v1

# Google Cloud → Web OAuth client ID (Gmail / Sign-In)
GOOGLE_SERVER_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
